# ---------------------------------------------------------
# BACKEND ENVIRONMENT VARIABLES (Render)
# ---------------------------------------------------------

PORT=3001

# Database & Redis (Render gives you these when you create them)
DATABASE_URL=postgres://user:pass@host:5432/db
REDIS_URL=redis://localhost:6379

# Cross-Origin Security
# Set this to your live Vercel URL
FRONTEND_URL=https://xenocrm.vercel.app

# Security Secrets (Generate random strings for these)
JWT_SECRET=super_secret_jwt_string_123
SESSION_SECRET=super_secret_session_string_456

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI Integration
GROQ_API_KEY=your-groq-api-key

# ---------------------------------------------------------
# CHANNEL SIMULATOR ROUTING
# ---------------------------------------------------------

# Where should the backend send outbound messages?
# (The live URL of your message-simulator service)
CHANNEL_STUB_URL=https://xenocrm-simulator.onrender.com

# What is THIS backend's own live URL?
# (The simulator will use this to send webhooks back to you)
CRM_API_URL=https://xenocrm-backend.onrender.com
